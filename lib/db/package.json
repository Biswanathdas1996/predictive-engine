{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "push": "python ../../scripts/local_secrets_export_dotenv.py && node --env-file=../../.env --env-file=../../secrets.dotenv ./node_modules/drizzle-kit/bin.cjs push --config ./drizzle.config.ts",
    "push-force": "python ../../scripts/local_secrets_export_dotenv.py && node --env-file=../../.env --env-file=../../secrets.dotenv ./node_modules/drizzle-kit/bin.cjs push --force --config ./drizzle.config.ts",
    "reset-schema": "python ../../scripts/local_secrets_export_dotenv.py && node --env-file=../../.env --env-file=../../secrets.dotenv ./scripts/reset-schema.mjs",
    "reset-db": "pnpm run reset-schema && pnpm run push"
  },
  "dependencies": {
    "drizzle-orm": "catalog:",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9"
  }
}
