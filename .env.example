# Copy to .env and fill in values. Never commit .env.
#
# python-dotenv does not override variables already set in your OS/shell.
# Blank keys in Windows User/System env no longer block non-empty values from this
# file (api-server fills blanks from .env for every key). DOTENV_OVERRIDE=1 still
# forces full .env override for all keys.
#
# Single secrets file (recommended): copy local_secrets.example.py → local_secrets.py
# at repo root (gitignored). The API loads it after .env for any still-blank vars.
# For Node/Drizzle: run `pnpm secrets:export` to write secrets.dotenv (gitignored);
# db scripts load .env then secrets.dotenv (later wins on duplicates).

# Neon / PostgreSQL (pooler URL recommended for server apps)
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require

# FastAPI server (artifacts/api-server-py). Vite proxies /api to this port in dev.
PORT=3000
# Optional: override API target for Vite dev proxy (defaults to 3000)
# API_PORT=3000

# ===========================================
# Database Pool
# ===========================================
# DB_POOL_MIN=2
# DB_POOL_MAX=20

# ===========================================
# Authentication (Required for production)
# ===========================================
# AUTH_MODE: none | api_key | jwt (default: none)
# AUTH_MODE=api_key
# API_KEYS=sk-your-key-1,sk-your-key-2
#
# For JWT mode:
# AUTH_MODE=jwt
# JWT_SECRET=your-256-bit-secret
# JWT_ALGORITHM=HS256

# ===========================================
# CORS (comma-separated origins, default: *)
# ===========================================
# CORS_ORIGINS=https://your-app.com,https://admin.your-app.com

# ===========================================
# Rate Limiting
# ===========================================
# RATE_LIMIT_REQUESTS=100
# RATE_LIMIT_WINDOW=60

# ===========================================
# Neo4j Graph Database (optional — graph features disabled if unset)
# ===========================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ===========================================
# Graph Backend for Simulations
# ===========================================
# Controls where the simulation engine reads the influence graph from.
# "postgres" (default) — reads agents & influences from PostgreSQL
# "neo4j" — reads from Neo4j graph DB (falls back to postgres if unavailable)
# GRAPH_BACKEND=postgres

# ===========================================
# PwC GenAI (required for simulation rounds — baseline and policy-linked)
# ===========================================
# Endpoint is OpenAI-style chat/completions; set model if your tenant requires it.
PWC_GENAI_ENDPOINT_URL=https://genai-sharedservice-americas.pwc.com/completions
# Use API key and/or bearer token as required by your PwC GenAI setup
# PWC_GENAI_API_KEY=
# PWC_GENAI_BEARER_TOKEN=
# PWC_GENAI_AUTH_MODE=auto|bearer|api_key|both (default auto: if API key equals bearer, only Bearer is sent — avoids some gateway 500s)
# PWC_GENAI_MODEL=
# PWC_GENAI_READ_TIMEOUT=60
# Optional: force OpenAI-style chat JSON on any endpoint (default: auto from URL — /completions uses prompt, /chat/completions uses messages)
# PWC_GENAI_USE_CHAT_MESSAGES=0
# PWC_GENAI_TOP_P=1
# PWC_GENAI_SEED=25
# Optional task YAML (repo root llm_config.yml or LLM_CONFIG_PATH) — per-task model, temperature, max_tokens, timeout
# LLM_CONFIG_PATH=
# LLM_MAX_CONCURRENCY=3
# LLM_MAX_RETRIES=5
# LLM_RETRY_BASE_DELAY=1.0
# LLM_RETRY_MAX_DELAY=30.0
# Max completion tokens per call (default 128; short JSON replies for agent actions)
# PWC_GENAI_MAX_TOKENS=128
#
# Policy-linked simulations: one LLM distillation per round from title+summary (not full attachments), then agents reuse the brief.
# PWC_GENAI_POLICY_BRIEF_CHARS=900
# PWC_GENAI_POLICY_BRIEF_INPUT_MAX=4000
# PWC_GENAI_POLICY_BRIEF_MAX_TOKENS=256
#
# Optional: PWC_GENAI_STRICT_PROBE=1 — if startup probe fails, disable GenAI (old behavior).
# Default: credentials in .env are enough; probe failure still enables rounds (runtime errors if unreachable).
# PWC_GENAI_SKIP_PROBE=1 — skip the probe entirely (same as failed probe + non-strict).

# Vertex AI — policy document processing (PDF page images + chunked text for docx/md/txt)
# Use Application Default Credentials (gcloud auth application-default login) or GOOGLE_APPLICATION_CREDENTIALS
# GOOGLE_CLOUD_PROJECT=your-gcp-project
# VERTEX_AI_LOCATION=us-central1
# Default model; set to your catalog id (e.g. PwC / enterprise Gemini image model)
# VERTEX_AI_MODEL=gemini-2.5-flash-image
